# ─── Auth (optional in dev) ───────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://127.0.0.1:3004
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple — co-equal identity (Apple-acquisition posture).
# Requires an Apple Developer account: a Services ID + a Sign in with Apple
# key (.p8). The client secret is generated dynamically (ES256 JWT) so there's
# no manual rotation. Leave blank to hide the Apple button in dev.
# NOTE: Apple rejects localhost — test via ngrok with an https NEXTAUTH_URL.
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=        # .p8 contents, newlines \n-escaped; use a secrets manager

# ─── LLMs (REQUIRED for chat) ─────────────────────
# Sona's runtime is all-Gemini for cost — Flash for text/reasoning,
# Flash Live for voice (Phase 2). Get a key at aistudio.google.com.
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash
# Native-audio dialog model (model hears + speaks; preserves pauses/tone).
# Prefer this over half-cascade "*-live" variants for natural turn-taking.
GEMINI_MODEL_FLASH_LIVE=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_MODEL_EMBEDDING=gemini-embedding-001
# Output dimensionality — must match prisma Memory.embedding vector(<n>).
GEMINI_EMBEDDING_DIM=1536

# Active LLM backend. All model calls route through lib/llm/provider.ts so the
# vendor is a swappable detail. "gemini" (default) | "apple-intelligence" (stub).
SONA_LLM_PROVIDER=gemini

# Phase 6 web-agent tasks (e.g. food ordering) use Gemini's
# computer-use / browser-control model — single vendor, no Anthropic.
# Override the model id here only if it differs from Flash.
GEMINI_MODEL_COMPUTER_USE=

# ─── Database (optional in dev) ───────────────────
# Postgres with pgvector. Without it, chat runs ephemeral (no persistence).
# Once set, run: npx prisma migrate dev
DATABASE_URL=

# Redis — alarm queue, session resume tokens, rate limits (Phase 4)
REDIS_URL=

# ─── Voice (Phase 2) ──────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PORCUPINE_ACCESS_KEY=

# ─── Tools (Phase 4+) ─────────────────────────────
TAVILY_API_KEY=
OPENWEATHER_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Apple / iCloud sync (Horizon 1 — CalDAV/CardDAV) ─────
# Per-user iCloud app-specific passwords are collected at runtime and stored
# encrypted (libsodium). This is the server-wide encryption key only.
# Generate: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=
# Apple Music developer token (MusicKit). Playback also needs a native Music
# User Token (Horizon 2), so this is staged but not yet wired end-to-end.
APPLE_MUSIC_DEVELOPER_TOKEN=

# ─── Web Push (Phase 4 — alarms surviving closed tabs) ─────
WEB_PUSH_VAPID_PUBLIC=
WEB_PUSH_VAPID_PRIVATE=
WEB_PUSH_CONTACT=mailto:hello@sona.app
